# ── Voice bot (client-side, must be NEXT_PUBLIC_*) ─────────────────────────────
# Public URL of the deployed Pipecat bot-server (the VPS), e.g. https://bot.cryptovoip.in
# Used by src/components/VoiceWidget.tsx. Falls back to http://localhost:8000 in dev.
NEXT_PUBLIC_BOT_BACKEND_URL=

# ── Contact form (server-side, used by src/app/api/contact/route.ts) ───────────
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=
# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=
# From address. Must be on a domain verified in Resend. Defaults to onboarding@resend.dev for testing.
CONTACT_FROM_EMAIL=

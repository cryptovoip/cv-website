# Daily WebRTC Transport
DAILY_API_KEY="get_your_key_from_dashboard.daily.co"

# LLM Provider (Currently using OpenAI in bot.py, but you can swap to Anthropic/Groq etc)
OPENAI_API_KEY="get_your_key_from_platform.openai.com"

# STT Provider (Deepgram is recommended for Pipecat)
DEEPGRAM_API_KEY="get_your_key_from_console.deepgram.com"

# TTS Provider (Cartesia is recommended for conversational Voice bots)
CARTESIA_API_KEY="get_your_key_from_play.cartesia.ai"

# SMTP Settings for Callbacks (cPanel or Gmail App Password)
SMTP_SERVER="mail.yourdomain.com_or_smtp.gmail.com"
SMTP_PORT="465_or_587"
SMTP_USER="bot@cryptovoip.in_or_gmail_address"
SMTP_PASS="your_email_password"
